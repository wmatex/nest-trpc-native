{
  "name": "nest-trpc-native-sample-09-config-middleware",
  "version": "0.0.0",
  "private": true,
  "description": "Sample 09 - forRootAsync with ConfigService and Nest middleware",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist src/@generated",
    "generate:types": "ts-node --transpile-only src/generate-types.ts",
    "typecheck": "npm run generate:types && tsc --noEmit -p tsconfig.json",
    "smoke": "npm run generate:types && ts-node --transpile-only scripts/smoke.ts",
    "test": "npm run typecheck && npm run smoke",
    "start": "npm run generate:types && ts-node src/main.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "nest-trpc-native": "0.3.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
