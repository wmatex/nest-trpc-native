{
  "name": "nest-trpc-native-showcase",
  "version": "0.0.0",
  "private": true,
  "description": "Showcase application for nest-trpc-native",
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist src/@generated",
    "generate:types": "ts-node --transpile-only src/generate-types.ts",
    "build": "npm run clean && npm run generate:types && nest build",
    "typecheck": "npm run generate:types && tsc --noEmit -p tsconfig.json",
    "typecheck:client": "npm run generate:types && tsc --noEmit -p tsconfig.client.json",
    "smoke:express": "npm run generate:types && ts-node --transpile-only scripts/smoke-express.ts",
    "smoke:fastify": "npm run generate:types && ts-node --transpile-only scripts/smoke-fastify.ts",
    "test": "npm run typecheck:client && npm run smoke:express && npm run smoke:fastify",
    "test:e2e": "npm run test",
    "start": "npm run generate:types && nest start",
    "start:dev": "npm run generate:types && nest start --watch",
    "start:fastify": "npm run generate:types && ts-node src/main-fastify.ts",
    "client": "npm run generate:types && ts-node src/client.ts",
    "client:subscription": "npm run generate:types && ts-node src/subscription-client.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/platform-fastify": "11.1.16",
    "nest-trpc-native": "0.3.0",
    "@trpc/client": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "eventsource": "4.1.0",
    "fastify": "5.8.2",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@types/node": "24.12.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
