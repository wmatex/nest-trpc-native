{
  "name": "nestjs-trpc",
  "version": "0.1.0",
  "private": true,
  "description": "Community standalone monorepo for @nestjs/trpc and showcase",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "showcase"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace @nestjs/trpc",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "TS_NODE_PROJECT=tsconfig.spec.json mocha packages/**/*.spec.ts",
    "test:cov": "TS_NODE_PROJECT=tsconfig.spec.json nyc mocha packages/**/*.spec.ts",
    "test:watch": "TS_NODE_PROJECT=tsconfig.spec.json mocha -w --watch-files \"packages\" packages/**/*.spec.ts",
    "pretypecheck:client": "npm run build --workspace @nestjs/trpc",
    "typecheck:client": "npm run typecheck:client --workspace @nestjs/trpc-showcase",
    "presmoke:express": "npm run build --workspace @nestjs/trpc",
    "smoke:express": "npm run smoke:express --workspace @nestjs/trpc-showcase",
    "presmoke:fastify": "npm run build --workspace @nestjs/trpc",
    "smoke:fastify": "npm run smoke:fastify --workspace @nestjs/trpc-showcase",
    "showcase": "npm run test --workspace @nestjs/trpc-showcase",
    "ci:showcase": "npm run typecheck:client && npm run smoke:express && npm run smoke:fastify",
    "ci": "npm run test:cov && npm run ci:showcase"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.16",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.4.0",
    "@types/sinon": "21.0.0",
    "chai": "4.5.0",
    "mocha": "11.7.5",
    "nyc": "^18.0.0",
    "rimraf": "6.1.3",
    "sinon": "21.0.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "mocha": {
    "require": [
      "ts-node/register",
      "node_modules/reflect-metadata/Reflect.js"
    ],
    "exit": true
  },
  "nyc": {
    "all": true,
    "extension": [
      ".ts"
    ],
    "include": [
      "packages/trpc/**/*.ts"
    ],
    "exclude": [
      "**/*.spec.ts",
      "**/test/**",
      "**/dist/**",
      "**/*.d.ts"
    ],
    "reporter": [
      "text",
      "text-summary",
      "json-summary",
      "lcov"
    ],
    "check-coverage": true,
    "branches": 100,
    "functions": 100,
    "lines": 100,
    "statements": 100,
    "cache": false
  }
}
