{
  "name": "nestjs-trpc",
  "version": "1.0.0",
  "description": "Official community tRPC integration for NestJS — native, decorator-first, full enhancer pipeline support. The spiritual successor to the closed PR #16553.",
  "author": "Rodrigo B. Nogueira (continuation of PR #16553)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/nestjs-trpc.git"
  },
  "homepage": "https://github.com/YOUR_USERNAME/nestjs-trpc#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/nestjs-trpc/issues"
  },
  "keywords": [
    "nestjs",
    "trpc",
    "typescript",
    "end-to-end-typesafe",
    "rpc",
    "nestjs-trpc",
    "nestjs integration"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "AI_CODING_GUIDELINES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "zod": "^3.22.0 || ^4.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@nestjs/testing": "^11.1.16",
    "@trpc/server": "^11.12.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.0"
  }
}