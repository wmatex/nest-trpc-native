    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "rxjs": "^7.8.1",
    "typescript": "^5.0.0"
