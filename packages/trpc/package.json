{
  "name": "nest-trpc-native",
  "version": "0.3.0",
  "description": "Decorator-first tRPC integration bridge for NestJS",
  "keywords": [
    "nestjs",
    "trpc",
    "nestjs-trpc",
    "typescript",
    "rpc",
    "decorators",
    "zero-deps"
  ],
  "author": "Rodrigo Nogueira",
  "license": "MIT",
  "homepage": "https://github.com/rodrigobnogueira/nest-trpc-native#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigobnogueira/nest-trpc-native.git",
    "directory": "packages/trpc"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "rxjs": "^7.8.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
