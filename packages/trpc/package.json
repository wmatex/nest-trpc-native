{
  "name": "@nestjs/trpc",
  "version": "11.1.16",
  "description": "Decorator-first tRPC integration bridge for NestJS",
  "author": "nest-trpc-native contributors",
  "license": "MIT",
  "homepage": "https://nestjs.com",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/nest"
  },
  "repository": {
    "type": "git",
